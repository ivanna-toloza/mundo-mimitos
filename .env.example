# GEMINI_API_KEY: Required for Gemini AI API calls.
# Configure this via your environment or .env.local file
GEMINI_API_KEY="YOUR_GEMINI_API_KEY"

# APP_URL: The URL where this app is hosted.
# Used for self-referential links and API endpoints.
APP_URL="http://localhost:3000"

# DATABASE_URL: PostgreSQL connection string.
# Format: postgresql://user:password@host:port/database
DATABASE_URL="postgresql://user:password@localhost:5432/mundo_mimitos"
